   "source": [
    "**MODEL 2: DEEP LEARNING (BIDIRECTIONAL LSTM ARCHITECTURE)**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 34,
   "metadata": {
    "colab": {
