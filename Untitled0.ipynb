    "#(cell-6) --- DIRECTORY CONFIGURATION ---\n",
    "# Dataset Drive Link: https://drive.google.com/drive/folders/1kKKOD1x0xJBcEWY9emdrtrFLSYQipkku?usp=drive_link\n",
    "ISOT_DIR = \"/content/drive/MyDrive/Assignment/ISOTFakeNews\"\n",
