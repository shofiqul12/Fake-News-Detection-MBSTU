   },
   "source": [
    "**MODEL 2: DEEP LEARNING (BIDIRECTIONAL LSTM ARCHITECTURE)**"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "-dEWOP0nwbwz"
   },
   "source": [
    "1. VOCABULARY & DATASET"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 53,
   "metadata": {
    "executionInfo": {
     "elapsed": 36868,
     "status": "ok",
     "timestamp": 1781036578188,
     "user": {
      "displayName": "bdinsider 360",
      "userId": "14876082496328581090"
     },
     "user_tz": -360
    },
    "id": "HZn7CM6tArvp"
   },
   "outputs": [],
   "source": [
    "# --- 1a. VOCABULARY & DATASET ---\n",
    "from collections import Counter\n",
    "counter = Counter()\n",
    "for text in train_df['content'].values: counter.update(clean_text(text).split())\n",
    "vocab = {'<PAD>': 0, '<UNK>': 1}\n",
    "for word, _ in counter.most_common(19998): vocab[word] = len(vocab)\n",
    "\n",
    "class TextDataset(Dataset):\n",
    "    def __init__(self, texts, labels, vocab, max_len=200):\n",
    "        self.labels, self.max_len, self.vocab = labels, max_len, vocab\n",
    "        self.data = [self._encode(t) for t in texts]\n",
    "    def _encode(self, text):\n",
    "        tokens = clean_text(text).split()[:self.max_len]\n",
    "        ids = [self.vocab.get(w, 1) for w in tokens]\n",
    "        ids += [0] * (self.max_len - len(ids))\n",
    "        return torch.tensor(ids, dtype=torch.long)\n",
    "    def __len__(self): return len(self.labels)\n",
    "    def __getitem__(self, i): return self.data[i], torch.tensor(self.labels[i], dtype=torch.long)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "jD1Aw0hOiXl4"
   },
   "source": [
    "2. LSTM ARCHITECTURE"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 54,
   "metadata": {
    "executionInfo": {
     "elapsed": 4,
     "status": "ok",
     "timestamp": 1781036578199,
     "user": {
      "displayName": "bdinsider 360",
      "userId": "14876082496328581090"
     },
     "user_tz": -360
    },
    "id": "n3ewp3tDArav"
   },
   "outputs": [],
   "source": [
    "# --- 1b. LSTM ARCHITECTURE ---\n",
    "class LSTMClassifier(nn.Module):\n",
    "    def __init__(self, vocab_size, embed_dim=100, hidden_dim=128):\n",
    "        super().__init__()\n",
    "        self.embedding = nn.Embedding(vocab_size, embed_dim, padding_idx=0)\n",
    "        self.lstm = nn.LSTM(embed_dim, hidden_dim, num_layers=2, batch_first=True, bidirectional=True)\n",
    "        self.fc = nn.Linear(hidden_dim * 2, 2)\n",
    "    def forward(self, x):\n",
    "        emb = self.embedding(x)\n",
    "        _, (h, _) = self.lstm(emb)\n",
    "        return self.fc(torch.cat([h[-2], h[-1]], dim=1))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "kbrZ8vOkieeg"
   },
   "source": [
    "3. TRAUPINING SET"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 55,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "executionInfo": {
     "elapsed": 113373,
     "status": "ok",
     "timestamp": 1781036691578,
     "user": {
      "displayName": "bdinsider 360",
      "userId": "14876082496328581090"
     },
     "user_tz": -360
    },
    "id": "uFdidKN_AyNx",
    "outputId": "36f5c567-9fe9-4e6d-e4d0-13423b4fe2d1"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "  Bi-LSTM Training Epoch 1/2 Execution Finished.\n",
      "  Bi-LSTM Training Epoch 2/2 Execution Finished.\n"
     ]
    }
   ],
   "source": [
    "# --- 1c. TRAUPINING SET ---\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "train_dl = DataLoader(TextDataset(train_df['content'].values, train_df['label'].values, vocab), batch_size=64, shuffle=True)\n",
    "val_dl = DataLoader(TextDataset(val_df['content'].values, val_df['label'].values, vocab), batch_size=64)\n",
    "\n",
    "lstm_model = LSTMClassifier(len(vocab)).to(device)\n",
    "criterion, optimizer = nn.CrossEntropyLoss(), torch.optim.Adam(lstm_model.parameters(), lr=1e-3)\n",
    "\n",
    "for epoch in range(2):\n",
    "    lstm_model.train()\n",
    "    for texts, labels in train_dl:\n",
    "        texts, labels = texts.to(device), labels.to(device)\n",
    "        optimizer.zero_grad(); criterion(lstm_model(texts), labels).backward(); optimizer.step()\n",
    "    print(f\"  Bi-LSTM Training Epoch {epoch+1}/2 Execution Finished.\")"
   ]
  },
