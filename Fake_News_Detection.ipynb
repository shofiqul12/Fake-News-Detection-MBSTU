    "#Performance Comparison Across Evaluation Scenarios\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "import os\n",
    "\n",
    "df = pd.DataFrame(global_metrics_summary)\n",
