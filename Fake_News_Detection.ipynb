    "#--- BERT FINE-TUNING ---\n",
    "print(\"\\n\" + \"=\"*60 + \"\\nMODEL 3: BERT TRANSFORMER TRAINING\\n\" + \"=\"*60)\n",
    "bert_model.train()\n",
    "\n",
    "for epoch in range(1):\n",
