    "        out = bert_model(batch['input_ids'].to(device), attention_mask=batch['attention_mask'].to(device), labels=batch['label'].to(device))\n",
    "        out.loss.backward()\n",
    "        optimizer.step()\n",
    "    print(f\"BERT Fine-Tuning Step Complete.\")"
